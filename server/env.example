# Copy this file to `.env` in the same directory and fill in your values

# Local server port
PORT=4000

# MongoDB connection string (include /ClubFinder before ? so data is not in "test")
# Example: mongodb+srv://<user>:<pass>@<cluster>/ClubFinder?retryWrites=true&w=majority
MONGO_URI=

# Verification emails are sent using SMTP credentials stored in environment variables.
EMAIL_USER=
EMAIL_PASS=
SHOW_RESET_ERRORS=true


