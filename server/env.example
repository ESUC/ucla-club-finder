# Copy this file to `.env` in the same directory and fill in your values

# Local server port
PORT=4000

# MongoDB connection string
# Example (MongoDB Atlas):
# mongodb+srv://<username>:<password>@<cluster-url>/<db-name>?retryWrites=true&w=majority
MONG_URI=

# Verification emails are sent using SMTP credentials stored in environment variables.
EMAIL_USER=
EMAIL_PASS=
SHOW_RESET_ERRORS=true


